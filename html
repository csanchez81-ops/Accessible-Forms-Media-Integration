<!DOCTYPE html>
<html>
<head>
    <title>Service Inquiry</title>
</head>
<body>
<CENTER>
<h2>Service Inquiry Form</h2>

<br>
<img src="r.png"alt="Logo" width="90"><br><br>
<br>


<form>

    Name:
        <input type="type" pattern="[A-Za-z\s]{3,}" required><br><br>

    Email:
        <input type="email" required><br><br>

    Password:
        <input type="password" required><br><br>

    Phone:
        <input type="tel" pattern="[0-9]{11}" required><br><br>

    Preferred Date:
        <input type="date" required><br><br>
    
    <button type="button">Submit</button>

    <CENTER/>



</form>

</body>
</html>
